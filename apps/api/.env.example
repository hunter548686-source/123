STABLEGPU_DATABASE_URL=sqlite:///./data/stablegpu.db
STABLEGPU_API_SECRET_KEY=stablegpu-dev-secret-2026-minimum-32bytes
STABLEGPU_ACCESS_TOKEN_EXPIRE_MINUTES=1440
STABLEGPU_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
STABLEGPU_WORKER_POLL_MAX_ATTEMPTS=8
STABLEGPU_REVIEW_MAX_ROUNDS=2
STABLEGPU_OPENAI_API_KEY=
STABLEGPU_OPENAI_BASE_URL=https://api.openai.com/v1
STABLEGPU_PLANNING_MODEL=gpt-5.4
STABLEGPU_REVIEW_MODEL=gpt-5.4
STABLEGPU_PROVIDER_MARKETPLACE_ADAPTER=database_mock
STABLEGPU_PROVIDER_MARKETPLACE_NAME=mock-aggregator
STABLEGPU_PROVIDER_MARKETPLACE_BASE_URL=
STABLEGPU_PROVIDER_MARKETPLACE_API_KEY=
STABLEGPU_PROVIDER_MARKETPLACE_REQUEST_TIMEOUT_SECONDS=30
STABLEGPU_VAST_AI_BASE_URL=https://console.vast.ai/api/v0
STABLEGPU_VAST_AI_API_KEY=
STABLEGPU_VAST_AI_REQUEST_TIMEOUT_SECONDS=30
STABLEGPU_VAST_AI_OFFERS_PATH=/bundles/
STABLEGPU_VAST_AI_SUBMIT_PATH=/tasks
STABLEGPU_VAST_AI_STATUS_PATH_TEMPLATE=/tasks/{external_task_id}
STABLEGPU_VAST_AI_CANCEL_PATH_TEMPLATE=/tasks/{external_task_id}/cancel
STABLEGPU_VAST_AI_RESULT_PATH_TEMPLATE=/tasks/{external_task_id}/result
STABLEGPU_VAST_AI_CLEANUP_PATH_TEMPLATE=/tasks/{external_task_id}/cleanup
STABLEGPU_RUNPOD_BASE_URL=https://rest.runpod.io/v1
STABLEGPU_RUNPOD_API_KEY=
STABLEGPU_RUNPOD_REQUEST_TIMEOUT_SECONDS=30
STABLEGPU_RUNPOD_OFFERS_PATH=/offers
STABLEGPU_RUNPOD_SUBMIT_PATH=/tasks
STABLEGPU_RUNPOD_STATUS_PATH_TEMPLATE=/tasks/{external_task_id}
STABLEGPU_RUNPOD_CANCEL_PATH_TEMPLATE=/tasks/{external_task_id}/cancel
STABLEGPU_RUNPOD_RESULT_PATH_TEMPLATE=/tasks/{external_task_id}/result
STABLEGPU_RUNPOD_CLEANUP_PATH_TEMPLATE=/tasks/{external_task_id}/cleanup
STABLEGPU_ENABLE_LOCAL_EXECUTOR=false
STABLEGPU_WSL_DISTRO=Ubuntu-24.04
STABLEGPU_OLLAMA_MODEL=qwen2.5-coder:14b
STABLEGPU_OLLAMA_PLANNER_MODEL=qwen2.5-coder:14b
STABLEGPU_OLLAMA_REVIEWER_MODEL=qwen2.5-coder:14b
STABLEGPU_OLLAMA_BASE_URL=http://host.docker.internal:11434
STABLEGPU_OLLAMA_REQUEST_TIMEOUT_SECONDS=180
